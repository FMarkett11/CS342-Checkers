<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.GridPane?>

<StackPane minHeight="360" minWidth="640" stylesheets="@../CSS/styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ClientController">
    <AnchorPane>
        <children>
            <ComboBox fx:id="connectedClients" layoutX="509.0" layoutY="3.0" prefHeight="10.0" prefWidth="86.0" />
            <ListView fx:id="chatList" layoutX="465.0" layoutY="58.0" prefHeight="301.0" prefWidth="175.0" />
            <TextField fx:id="messageField" layoutX="478.0" layoutY="31.0" onAction="#sendChat" promptText="Enter text:" />
         <Label fx:id="dispMsg" layoutX="14.0" layoutY="58.0" styleClass="LoginLabel" text="Awaiting User..." textAlignment="CENTER" />
         <Button layoutX="14.0" layoutY="16.0" mnemonicParsing="false" onAction="#goBack" text="Back" />
            <ImageView fitHeight="378.0" fitWidth="414.0" layoutX="14.0" layoutY="116.0">
                <Image fx:id="board" url="@../Images/checkerboard.jpg" />
            </ImageView>
            <GridPane fx:id="boardGrid" layoutX="14.0" layoutY="116.0" prefWidth="414.0" prefHeight="378.0" />
        </children></AnchorPane>
</StackPane>
