<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane minHeight="360" minWidth="640" stylesheets="@../CSS/styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ClientController">
    <AnchorPane>
        <children>
            <ComboBox fx:id="connectedClients" layoutX="509.0" layoutY="3.0" prefHeight="10.0" prefWidth="86.0" />
            <ListView fx:id="chatList" layoutX="465.0" layoutY="58.0" prefHeight="301.0" prefWidth="175.0" />
            <TextField fx:id="messageField" layoutX="478.0" layoutY="31.0" onAction="#sendChat" promptText="Enter text:" />
         <Label fx:id="dispMsg" layoutX="14.0" layoutY="58.0" styleClass="LoginLabel" text="Awaiting User..." textAlignment="CENTER" />
         <Button layoutX="14.0" layoutY="16.0" mnemonicParsing="false" onAction="#goBack" text="Back" />
            <ImageView fitHeight="378.0" fitWidth="414.0" layoutX="14.0" layoutY="116.0">
                <Image url="@../Images/checkerboard.jpg" />
            </ImageView>
            <GridPane fx:id="boardGrid" layoutX="36.0" layoutY="136.0" prefHeight="337.0" prefWidth="370.0">
            <columnConstraints>
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
            </rowConstraints></GridPane>
            <StackPane fx:id="overlay" mouseTransparent = "true" prefHeight="494.0" prefWidth="641.0" style="-fx-background-color: rgba(0,0,0,0.8);" visible="false">
                <VBox fx:id="Rematch" alignment="CENTER" maxWidth="657.0" prefHeight="494.0" prefWidth="657.0" spacing="40">
                    <Label fx:id="winlose" styleClass="LoginLabel" text="You Win!" />
                    <Label styleClass="CreationLabel" text="" />
                    <Label styleClass="CreationLabel" text="Rematch?" />
                    <HBox alignment="CENTER" prefHeight="90.0" prefWidth="363.0" spacing="20">
                        <Button onAction="#goBack" prefHeight="90.0" prefWidth="200" styleClass="primary-button" text="No" />
                        <Button onAction="#rematch" prefHeight="90.0" prefWidth="200" styleClass="other-primary-button" text="Yes" />
                    </HBox>
                </VBox>
            </StackPane>
        </children></AnchorPane>
</StackPane>
